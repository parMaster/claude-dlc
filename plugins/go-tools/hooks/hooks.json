{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-explore-in-go.py",
            "statusMessage": "Checking agent type..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-gosymdb-pipe.py",
            "statusMessage": "Checking gosymdb usage..."
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-go-symbol-grep.py",
            "statusMessage": "Checking for Go symbol grep..."
          }
        ]
      }
    ]
  }
}
